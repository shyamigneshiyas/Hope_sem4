class Solution {
    public int pivotIndex(int[] nums) {
        int left=0;
        int right=0;
        int tot=0;
        for(int n:nums){
            tot+=n;
        }
        for(int i=0;i<nums.length;i++){
            right=tot-left-nums[i];
            if(left==right) return i;
            left+=nums[i];
        }
        return -1;
    }
}
